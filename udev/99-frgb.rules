SUBSYSTEM=="usb", ATTR{idVendor}=="1a86", ATTR{idProduct}=="ad22", MODE="0666"

# --- Force usbhid to bind HID interfaces the kernel may not claim ---

# HydroShift LCD AIO
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7398", RUN+="/bin/sh -c 'echo 0416 7398 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7399", RUN+="/bin/sh -c 'echo 0416 7399 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="739a", RUN+="/bin/sh -c 'echo 0416 739a > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

# Galahad II LCD / Vision AIO
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7391", RUN+="/bin/sh -c 'echo 0416 7391 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="7395", RUN+="/bin/sh -c 'echo 0416 7395 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

# Universal Screen 8.8" LED Ring
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0416", ATTR{idProduct}=="8050", RUN+="/bin/sh -c 'echo 0416 8050 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

