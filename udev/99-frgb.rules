ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a103", RUN+="/bin/sh -c 'echo 0cf2 a103 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a104", RUN+="/bin/sh -c 'echo 0cf2 a104 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a105", RUN+="/bin/sh -c 'echo 0cf2 a105 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="0cf2", ATTR{idProduct}=="a106", RUN+="/bin/sh -c 'echo 0cf2 a106 > /sys/bus/usb/drivers/usbhid/new_id 2>/dev/null || true'"

