# ---------------------------------------------------------------------------
# Motherboard hwmon PWM access (Super I/O chips — nct6xxx, it87xx, etc.)
#
# Group-gated (not 0666 like the USB rules above) because writing to pwm*
# can stall fans / overheat hardware if misused. User must be in the `frgb`
# group to control motherboard fans.
#
# Install:
#   sudo groupadd -r frgb
#   sudo usermod -aG frgb $USER    # log out/in to take effect
#   sudo cp udev/99-frgb.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger -s hwmon
# ---------------------------------------------------------------------------
SUBSYSTEM=="hwmon", KERNEL=="hwmon*", RUN+="/bin/sh -c 'for f in /sys%p/pwm* ; do [ -f $$f ] && chmod 0664 $$f && chgrp frgb $$f 2>/dev/null || true ; done'"
