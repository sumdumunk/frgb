// Color palette — dark theme inspired by hardware control software
export global Theme {
    // Backgrounds
    out property <color> bg-primary: #0d0d0d;
    out property <color> bg-secondary: #111111;
    out property <color> bg-surface: #151515;
    out property <color> bg-hover: #1a1a1a;
    out property <color> bg-active: #1a1f2e;

    // Borders
    out property <color> border-subtle: #1a1a1a;
    out property <color> border-default: #222222;
    out property <color> border-strong: #333333;

    // Text
    out property <color> text-primary: #e0e0e0;
    out property <color> text-secondary: #888888;
    out property <color> text-muted: #555555;
    out property <color> text-disabled: #333333;

    // Accent
    out property <color> accent: #4a9eff;
    out property <color> accent-bg: #1a2a3a;

    // Status
    out property <color> status-online: #6cc4a1;
    out property <color> status-offline: #555555;
    out property <color> status-pump: #ff6b35;
    out property <color> status-warn: #e8a04c;
    out property <color> status-error: #d46c6c;

    // Role colors (pastel)
    out property <color> role-intake: #6ca6d4;
    out property <color> role-exhaust: #d46c6c;
    out property <color> role-pump: #d4956c;

    // Sizing
    out property <length> sidebar-width: 220px;
    out property <length> topbar-height: 36px;
    out property <length> statusbar-height: 26px;
    out property <length> tabbar-height: 38px;

    // Typography
    out property <length> font-xs: 10px;
    out property <length> font-sm: 11px;
    out property <length> font-base: 13px;
    out property <length> font-lg: 15px;
    out property <length> font-xl: 18px;

    // Badge colors (pastel)
    out property <color> badge-fan: #6ca6d4;
    out property <color> badge-rgb: #d4789c;
    out property <color> badge-lcd: #9c7cc4;
    out property <color> badge-pump: #5cb8a8;
}
